---
const testimonials = [
  {
    quote: 'ProgramMasters made us look like a much bigger company without losing clarity. The site now does half of the sales conversation before we even get on a call.',
    name: 'Mariana Rojas',
    role: 'Founder, Estudio North',
    image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=400&q=80',
  },
  {
    quote: 'The difference was immediate. Better inquiries, stronger positioning and a visual language that finally matched the level of our service.',
    name: 'Daniel Herrera',
    role: 'Director, Atelier Legal',
    image: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=400&q=80',
  },
];
---

<section class="section relative">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Testimonials</div>
        <h2 class="section-title">
          Credibility comes from the client voice, not our adjectives.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          The strongest websites make clients feel the shift before they measure it.
        </p>
      </h2>
      </div>

      <div class="lg:col-span-8 grid gap-5 md:grid-cols-2">
        {
          testimonials.map((testimonial) => (
            <article class="panel panel-hover flex h-full flex-col justify-between p-8 sm:p-10">
              <p class="text-xl leading-9 tracking-[-0.03em] text-white sm:text-2xl sm:leading-10">
                “{testimonial.quote}”
              </p>

              <div class="mt-10 flex items-center gap-4 border-t border-white/10 pt-6">
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="h-14 w-14 rounded-full object-cover"
                  loading="lazy"
                />
                <div>
                  <div class="font-semibold tracking-[-0.02em] text-white">{testimonial.name}</div>
                  <div class="text-sm text-brand-muted">{testimonial.role}</div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
