---
---

<section id="top" class="relative overflow-hidden pt-36 pb-24 sm:pt-40 sm:pb-28 lg:pt-44">
  <div class="grid-bg absolute inset-0"></div>

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="eyebrow mb-6">
          <span class="h-2 w-2 rounded-full bg-brand-yellow animate-pulse"></span>
          Sitios web desde $50 · Entrega en 3 días
        </div>

        <h1 class="heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[0.95]">
          Transformamos tu <span class="text-brand-blue">idea</span> en una<br class="hidden sm:block" />
          <span class="text-brand-red">presencia digital</span><br class="hidden sm:block" />
          que genera resultados
        </h1>

        <p class="mt-8 text-lg sm:text-xl text-brand-muted max-w-2xl leading-relaxed">
          Somos <strong class="text-white">developers y diseñadores gráficos</strong> profesionales
          apoyando a emprendedores venezolanos y latinoamericanos a lanzar su negocio en internet,
          <strong class="text-white"> sin gastar cientos de dólares</strong>.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a href="#planes" class="btn-primary text-base">
            Ver planes
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="https://wa.me/584244074025?text=Hola%20ProgramMasters%2C%20me%20interesa%20un%20sitio%20web"
            target="_blank"
            rel="noopener"
            class="btn-secondary text-base"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.695.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribir por WhatsApp
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-brand-muted">
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F4B400" stroke-width="3">
              <path d="M5 12l5 5L20 7"/>
            </svg>
            Subdominio gratis
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F4B400" stroke-width="3">
              <path d="M5 12l5 5L20 7"/>
            </svg>
            Dominio propio disponible
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F4B400" stroke-width="3">
              <path d="M5 12l5 5L20 7"/>
            </svg>
            Diseño profesional
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="relative animate-floaty">
          <div class="absolute -inset-8 bg-gradient-to-br from-brand-blue/30 via-transparent to-brand-red/30 blur-3xl"></div>

          <div class="relative rounded-3xl border border-white/10 bg-gradient-to-br from-brand-surface to-brand-bgAlt p-6 shadow-glow">
            <div class="flex items-center gap-2 mb-4">
              <span class="h-3 w-3 rounded-full bg-red-500"></span>
              <span class="h-3 w-3 rounded-full bg-yellow-500"></span>
              <span class="h-3 w-3 rounded-full bg-green-500"></span>
              <span class="ml-auto text-xs text-brand-muted">tunegocio.programmasters.net</span>
            </div>

            <div class="rounded-2xl bg-brand-bg overflow-hidden">
              <div class="h-40 bg-gradient-to-br from-brand-blue via-brand-blueDark to-brand-red p-6 flex flex-col justify-end">
                <div class="text-xs font-semibold uppercase tracking-widest text-white/70">Tu Negocio</div>
                <div class="text-2xl font-black text-white leading-tight mt-1">Diseño que<br/>conecta.</div>
              </div>
              <div class="p-5 space-y-3">
                <div class="h-2 rounded bg-white/10 w-3/4"></div>
                <div class="h-2 rounded bg-white/10 w-full"></div>
                <div class="h-2 rounded bg-white/10 w-5/6"></div>
                <div class="pt-2 flex gap-2">
                  <div class="h-8 rounded-full bg-brand-blue px-4 flex items-center text-xs font-semibold text-white">
                    WhatsApp
                  </div>
                  <div class="h-8 rounded-full border border-white/15 px-4 flex items-center text-xs font-semibold text-white">
                    Ver más
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-6 -left-6 rounded-2xl border border-white/10 bg-brand-bgAlt/95 backdrop-blur-md px-4 py-3 shadow-glowRed">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-brand-red/20 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C0202B" stroke-width="2.5">
                  <path d="M13 2 3 14h9l-1 8 10-12h-9z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs text-brand-muted">Carga en</div>
                <div class="text-sm font-bold text-white">&lt; 1 segundo</div>
              </div>
            </div>
          </div>

          <div class="absolute -top-6 -right-4 rounded-2xl border border-white/10 bg-brand-bgAlt/95 backdrop-blur-md px-4 py-3 shadow-glow">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-brand-yellow/20 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#F4B400">
                  <path d="M12 2l3 7 7 .5-5.5 4.5L18 22l-6-4-6 4 1.5-8L2 9.5 9 9z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs text-brand-muted">Diseño</div>
                <div class="text-sm font-bold text-white">Personalizado</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
