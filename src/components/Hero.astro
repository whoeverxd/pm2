---
const stats = [
  'Trusted by scaling companies',
  '850+ Projects Delivered',
  '12 Countries',
  '100% Custom Design',
];
---

<section id="top" class="relative overflow-hidden pt-32 sm:pt-36 lg:pt-40">
  <div class="grid-fade absolute inset-0"></div>

  <div class="container-x relative">
    <div class="grid gap-14 border-b border-white/10 pb-20 lg:grid-cols-12 lg:items-end lg:gap-10 lg:pb-28">
      <div class="lg:col-span-7 xl:col-span-6">
        <div class="eyebrow mb-8">
          <span class="h-2 w-2 rounded-full bg-brand-yellow"></span>
          Premium websites for brands that need growth, not decoration
        </div>

        <h1 class="heading max-w-4xl text-[3.25rem] leading-[0.9] sm:text-[4.5rem] lg:text-[5.5rem] xl:text-[6.75rem]">
          We build websites that actually generate clients.
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-brand-muted sm:text-xl">
          ProgramMasters combines senior strategy, conversion-focused UX and precise execution to
          launch digital experiences that look premium and perform like a sales asset.
        </p>

        <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="#contacto" class="btn-primary text-base">
            Get a Proposal
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#proyectos" class="btn-secondary text-base">View Portfolio</a>
        </div>

        <div class="mt-14 grid max-w-3xl gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {
            stats.map((stat) => (
              <div class="rounded-[20px] border border-white/10 bg-white/[0.025] px-5 py-5 backdrop-blur-sm transition duration-300 hover:border-white/20 hover:bg-white/[0.045]">
                <div class="text-sm font-medium tracking-[-0.02em] text-white">{stat}</div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5 xl:col-span-6">
        <div class="relative mx-auto max-w-[640px] lg:ml-auto">
          <div class="absolute -left-10 top-10 h-40 w-40 rounded-full bg-brand-blue/20 blur-3xl"></div>
          <div class="absolute bottom-8 right-6 h-48 w-48 rounded-full bg-brand-yellow/10 blur-3xl"></div>

          <div class="panel animate-floaty relative overflow-hidden rounded-[28px] p-3 sm:p-4">
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),transparent_22%)]"></div>

            <div class="relative rounded-[24px] border border-white/10 bg-[#0A1120] p-3 shadow-[0_40px_120px_-56px_rgba(0,0,0,1)]">
              <div class="flex items-center gap-2 border-b border-white/10 px-3 pb-3 sm:px-4">
                <span class="h-2.5 w-2.5 rounded-full bg-white/25"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/15"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
                <div class="ml-3 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-[11px] text-brand-muted">
                  atelier.programmasters.com
                </div>
              </div>

              <div class="grid gap-4 p-3 sm:p-4">
                <div class="overflow-hidden rounded-[22px] border border-white/10 bg-[#0F172B]">
                  <div class="grid gap-8 border-b border-white/10 px-5 py-6 sm:grid-cols-[1.1fr_0.9fr] sm:px-6 sm:py-7">
                    <div>
                      <div class="text-[11px] uppercase tracking-[0.26em] text-brand-muted">Launch Campaign</div>
                      <div class="mt-3 max-w-[280px] text-2xl font-semibold tracking-[-0.05em] text-white sm:text-[2rem]">
                        A conversion-first site for a fast-growing service brand.
                      </div>
                    </div>
                    <div class="grid gap-3 sm:pl-6">
                      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                        <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Live In</div>
                        <div class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-white">12 days</div>
                      </div>
                      <div class="rounded-2xl border border-brand-yellow/15 bg-brand-yellow/[0.08] p-4">
                        <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Lead Quality</div>
                        <div class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-white">+38%</div>
                      </div>
                    </div>
                  </div>

                  <div class="grid gap-4 px-5 py-5 sm:grid-cols-[1.15fr_0.85fr] sm:px-6 sm:py-6">
                    <div class="rounded-[22px] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.22),transparent_42%),radial-gradient(circle_at_85%_14%,rgba(232,197,71,0.12),transparent_24%),linear-gradient(180deg,#111b32_0%,#0b1325_100%)] p-6">
                      <div class="flex items-center justify-between">
                        <div>
                          <div class="text-[11px] uppercase tracking-[0.24em] text-white/50">Homepage</div>
                          <div class="mt-2 text-xl font-semibold tracking-[-0.04em] text-white">Editorial hero layout</div>
                        </div>
                        <div class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] text-white/70">Desktop</div>
                      </div>
                      <div class="mt-8 space-y-3">
                        <div class="h-3 w-24 rounded-full bg-white/15"></div>
                        <div class="h-6 w-full rounded-full bg-white/10"></div>
                        <div class="h-6 w-[92%] rounded-full bg-white/10"></div>
                        <div class="h-6 w-[74%] rounded-full bg-white/10"></div>
                      </div>
                      <div class="mt-8 grid grid-cols-3 gap-3">
                        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-3">
                          <div class="h-20 rounded-2xl bg-white/10"></div>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-3">
                          <div class="h-20 rounded-2xl bg-brand-yellow/15"></div>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-3">
                          <div class="h-20 rounded-2xl bg-white/10"></div>
                        </div>
                      </div>
                    </div>

                    <div class="grid gap-4">
                      <div class="rounded-[22px] border border-white/10 bg-white/[0.03] p-4">
                        <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Messaging</div>
                        <div class="mt-3 text-lg font-semibold tracking-[-0.03em] text-white">Clear positioning. Zero clutter.</div>
                      </div>
                      <div class="rounded-[22px] border border-white/10 bg-white/[0.03] p-4">
                        <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Performance</div>
                        <div class="mt-3 text-lg font-semibold tracking-[-0.03em] text-white">Sub-second loading with modern code.</div>
                      </div>
                      <div class="rounded-[22px] border border-brand-yellow/15 bg-[linear-gradient(180deg,rgba(59,130,246,0.14),rgba(232,197,71,0.05))] p-4">
                        <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Craft</div>
                        <div class="mt-3 text-lg font-semibold tracking-[-0.03em] text-white">Built like a premium product, not a template.</div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="grid gap-3 sm:grid-cols-3">
                  <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                    <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Industry</div>
                    <div class="mt-2 text-base font-semibold tracking-[-0.03em] text-white">Professional Services</div>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                    <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Scope</div>
                    <div class="mt-2 text-base font-semibold tracking-[-0.03em] text-white">Strategy, UX, Visual Design</div>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                    <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Outcome</div>
                    <div class="mt-2 text-base font-semibold tracking-[-0.03em] text-white">Higher intent inquiries</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
