---
import Logo from './Logo.astro';

const links = [
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#resultados', label: 'Resultados' },
  { href: '#planes', label: 'Precios' },
  { href: '#faq', label: 'FAQ' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <div class="container-x pt-5">
    <div class="flex items-center justify-between rounded-full border border-white/10 bg-brand-bg/72 px-4 py-3 shadow-[0_24px_80px_-48px_rgba(0,0,0,0.95)] backdrop-blur-xl sm:px-5">
    <div class="flex items-center gap-4">
      <Logo />
      <span class="accent-chip hidden xl:inline-flex">Presencia digital clara para negocios reales</span>
    </div>

    <nav class="hidden lg:flex items-center gap-8 rounded-full px-6 py-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-sm font-medium text-brand-muted transition hover:text-brand-yellowSoft"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contacto" class="hidden sm:inline-flex btn-primary px-5 py-2.5">
        Hablemos
      </a>
      <button
        id="menu-toggle"
        class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white transition hover:border-brand-yellow/40 hover:text-brand-yellowSoft"
        aria-label="Abrir menú"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden container-x pb-4"
  >
    <div class="mt-3 rounded-[20px] border border-white/10 bg-brand-surface/95 p-4 backdrop-blur-xl">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="mobile-link block rounded-2xl px-4 py-3 text-sm font-medium text-brand-muted transition hover:bg-white/5 hover:text-brand-yellowSoft"
          >
            {l.label}
          </a>
        ))
      }
      <a href="#contacto" class="mobile-link btn-primary mt-3 w-full">Hablemos</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const setScrolled = () => {
    if (!header) return;
    if (window.scrollY > 12) {
      header.classList.add('translate-y-0');
    } else {
      header.classList.remove('translate-y-0');
    }
  };
  setScrolled();
  window.addEventListener('scroll', setScrolled, { passive: true });

  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document
    .querySelectorAll('.mobile-link')
    .forEach((a) => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
