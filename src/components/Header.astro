---
import Logo from './Logo.astro';

const links = [
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#planes', label: 'Planes' },
  { href: '#mantenimiento', label: 'Mantenimiento' },
  { href: '#faq', label: 'FAQ' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <div class="container-x flex items-center justify-between py-4">
    <Logo />

    <nav class="hidden lg:flex items-center gap-8 rounded-full border border-white/10 bg-brand-bg/70 px-6 py-2 backdrop-blur-md">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-sm font-medium text-brand-muted transition hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contacto" class="hidden sm:inline-flex btn-primary text-sm px-5 py-2.5">
        Hablemos
      </a>
      <button
        id="menu-toggle"
        class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-full border border-white/10 bg-white/5"
        aria-label="Abrir menú"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden container-x pb-4"
  >
    <div class="rounded-2xl border border-white/10 bg-brand-bgAlt/95 backdrop-blur-md p-4 space-y-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="mobile-link block rounded-lg px-4 py-3 text-sm font-medium text-brand-muted hover:bg-white/5 hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
      <a href="#contacto" class="mobile-link btn-primary w-full text-sm mt-2">Hablemos</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const setScrolled = () => {
    if (!header) return;
    if (window.scrollY > 12) {
      header.classList.add('bg-brand-bg/80', 'backdrop-blur-md', 'border-b', 'border-white/5');
    } else {
      header.classList.remove('bg-brand-bg/80', 'backdrop-blur-md', 'border-b', 'border-white/5');
    }
  };
  setScrolled();
  window.addEventListener('scroll', setScrolled, { passive: true });

  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document
    .querySelectorAll('.mobile-link')
    .forEach((a) => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
