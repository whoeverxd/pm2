---
const plans = [
  {
    name: 'Basico',
    price: '$5/mes',
    summary: 'Actualizaciones de seguridad y monitoreo 24/7.',
    accent: 'text-brand-blue',
    border: 'border-brand-blue/35 hover:border-brand-blue/55',
    surface: 'bg-[linear-gradient(180deg,rgba(18,31,57,0.92),rgba(12,20,36,0.96))]',
    features: ['Hosting incluido', 'SSL Gratis'],
  },
  {
    name: 'Estandar',
    price: '$15/mes',
    summary: 'Cambios menores de contenido y backups semanales.',
    accent: 'text-[rgb(129,29,39)]',
    border: 'border-[rgb(129,29,39)]/45 hover:border-[rgb(129,29,39)]/70',
    surface: 'bg-[linear-gradient(180deg,rgba(49,16,23,0.94),rgba(23,11,16,0.97))]',
    features: ['Todo lo del Basico', 'Soporte por Email'],
  },
  {
    name: 'Avanzado',
    price: '$35/mes',
    summary: 'SEO continuo y optimizacion de velocidad mensual.',
    accent: 'text-brand-yellowSoft',
    border: 'border-brand-yellow/35 hover:border-brand-yellow/55',
    surface: 'bg-[linear-gradient(180deg,rgba(53,42,11,0.92),rgba(23,18,7,0.96))]',
    features: ['Todo lo del Estandar', 'Reporte de Trafico'],
  },
  {
    name: 'Corporativo',
    price: 'Personalizado',
    summary: 'Infraestructura dedicada y soporte de emergencia.',
    accent: 'text-brand-blue',
    border: 'border-brand-blue/35 hover:border-brand-blue/55',
    surface: 'bg-[linear-gradient(180deg,rgba(18,31,57,0.92),rgba(12,20,36,0.96))]',
    features: ['SLAs Garantizados', 'Account Manager'],
  },
];
---

<section id="resultados" class="section relative pt-0">
  <div class="container-x">
    <div class="px-0 py-2 sm:py-4">
      <div>
        <h2 class="text-[2rem] font-semibold tracking-[-0.05em] text-white sm:text-[2.4rem]">
          Mantenimiento Mensual
        </h2>
        <p class="mt-3 text-base leading-7 text-brand-muted sm:text-lg">
          Mantén tu sitio seguro, rápido y siempre online.
        </p>

        <div class="mt-10 grid gap-5 lg:grid-cols-4">
          {
            plans.map((plan) => (
              <article class={`min-h-[250px] rounded-[14px] border p-6 transition duration-300 ${plan.border} ${plan.surface}`}>
                <div class={`text-xl font-semibold ${plan.accent}`}>{plan.name}</div>
                <div class="mt-4 text-[2rem] font-medium tracking-[-0.05em] text-white">{plan.price}</div>
                <p class="mt-5 max-w-[22ch] text-base leading-8 text-white/80">{plan.summary}</p>

                <ul class="mt-5 space-y-2 text-sm leading-7 text-brand-muted">
                  {plan.features.map((feature) => (
                    <li>• {feature}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
