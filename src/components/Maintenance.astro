---
const tiers = [
  {
    name: 'Básico',
    price: '$5',
    accent: 'text-brand-blue',
    ring: 'ring-brand-blue/30',
    features: ['Hosting activo', '1 cambio al mes', 'Copias de seguridad'],
  },
  {
    name: 'Estándar',
    price: '$10',
    accent: 'text-brand-red',
    ring: 'ring-brand-red/30',
    features: ['Hasta 4 cambios al mes', 'Gestión de Google Business', 'Copias de seguridad'],
  },
  {
    name: 'Avanzado',
    price: '$18',
    accent: 'text-brand-yellow',
    ring: 'ring-brand-yellow/30',
    features: ['Cambios ilimitados razonables', 'Gestión de reseñas', 'Prioridad media'],
    highlight: true,
  },
  {
    name: 'Corporativo',
    price: '$30',
    accent: 'text-white',
    ring: 'ring-white/20',
    features: ['Soporte prioritario', 'Reportes mensuales', 'Acompañamiento estratégico'],
  },
];
---

<section id="mantenimiento" class="section relative">
  <div class="container-x">
    <div class="max-w-3xl">
      <div class="eyebrow mb-5">Mantenimiento mensual</div>
      <h2 class="heading text-3xl sm:text-4xl lg:text-5xl leading-tight">
        Un sitio web <span class="text-brand-yellow">se cuida</span>, no se abandona.
      </h2>
      <p class="mt-5 text-lg text-brand-muted leading-relaxed">
        Elige un plan de mantenimiento y olvídate de fallas, cambios y actualizaciones.
        Se acopla a cualquier plan de la sección anterior.
      </p>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        tiers.map((t) => (
          <div class={`card card-hover p-6 ring-1 ${t.ring} ${t.highlight ? 'lg:-translate-y-2' : ''}`}>
            <div class="text-xs font-bold uppercase tracking-widest text-brand-muted">{t.name}</div>
            <div class="mt-3 flex items-baseline gap-1">
              <span class={`font-display font-black text-4xl ${t.accent}`}>{t.price}</span>
              <span class="text-sm text-brand-muted">/mes</span>
            </div>

            <div class="my-5 h-px bg-white/10"></div>

            <ul class="space-y-2.5 text-sm">
              {t.features.map((f) => (
                <li class="flex items-start gap-2 text-white/90">
                  <svg class="mt-0.5 shrink-0 text-brand-yellow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M5 12l5 5L20 7"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
