---
const stats = [
  { value: '850+', label: 'Projects delivered across service, consulting and premium local brands.' },
  { value: '12', label: 'Countries reached with launches for Spanish-speaking and international audiences.' },
  { value: '94%', label: 'Of clients arrive through referrals or repeat engagements.' },
  { value: '<1s', label: 'Typical load performance on our Astro-based production builds.' },
];
---

<section id="resultados" class="section relative">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Why Choose Us</div>
        <h2 class="section-title">
          Stronger proof. Less marketing noise.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          We prefer measurable outcomes and disciplined execution over inflated agency language.
        </p>
      </h2>
      </div>

      <div class="lg:col-span-8 grid gap-5 sm:grid-cols-2">
        {
          stats.map((stat) => (
            <article class="panel panel-hover min-h-[250px] p-8 sm:p-10">
              <div class="text-[3rem] font-semibold tracking-[-0.06em] text-white sm:text-[4rem]">{stat.value}</div>
              <p class="mt-6 max-w-sm text-base leading-8 text-brand-muted">{stat.label}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
