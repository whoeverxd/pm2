---
interface Props {
  size?: number;
  withTagline?: boolean;
  class?: string;
}

const { size = 44, withTagline = false, class: className = '' } = Astro.props;
---

<a href="#top" class={`inline-flex items-center gap-3 ${className}`} aria-label="ProgramMasters — Inicio">
  <img
    src="/isotipo.png"
    alt=""
    width={size}
    height={size}
    class="h-auto shrink-0 object-contain"
    loading="eager"
    decoding="async"
    aria-hidden="true"
  />
  <div class="leading-tight">
    <span class="block font-display text-lg tracking-[-0.05em] text-white">
      ProgramMasters
    </span>
    {
      withTagline && (
        <span class="block text-[10px] font-semibold uppercase tracking-[0.28em] text-brand-muted">
          Premium Digital Craft
        </span>
      )
    }
  </div>
</a>
