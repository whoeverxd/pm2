---
const services = [
  {
    number: '01',
    title: 'Brand Positioning Websites',
    description: 'Premium websites that clarify your offer, sharpen trust and convert high-intent visitors into conversations.',
  },
  {
    number: '02',
    title: 'High-Converting Landing Pages',
    description: 'Campaign-focused pages built for launches, paid traffic, partnerships and service validation.',
  },
  {
    number: '03',
    title: 'Custom Design Systems',
    description: 'Editorial UI direction, scalable components and brand-consistent interfaces that do not feel templated.',
  },
];
---

<section id="servicios" class="section relative">
  <div class="container-x">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Services</div>
        <h2 class="section-title">
          A focused set of offers built for ambitious service brands.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          No bloated retainers, no vague deliverables. Just the design and web systems that materially improve how your company is perceived online.
        </p>
      </h2>
      </div>

      <div class="lg:col-span-8 grid gap-5 md:grid-cols-3">
        {
          services.map((service) => (
            <article class="panel panel-hover flex min-h-[320px] flex-col justify-between p-7">
              <div>
                <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">{service.number}</div>
                <h3 class="mt-10 text-2xl font-semibold tracking-[-0.04em] text-white">{service.title}</h3>
                <p class="mt-4 text-base leading-8 text-brand-muted">{service.description}</p>
              </div>
              <div class="mt-10 flex items-center gap-3 text-sm text-white/75">
                <span class="h-10 w-10 rounded-full border border-white/10 bg-white/[0.04] flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                  </svg>
                </span>
                Built for differentiation
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
        </div>
      </div>
    </div>
  </div>
</section>
