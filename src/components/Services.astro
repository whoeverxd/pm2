---
const services = [
  {
    number: '01',
    title: 'Landing sencilla',
    description: 'Una página clara para presentar tu negocio, servicios, horarios, precios y botón directo a WhatsApp.',
  },
  {
    number: '02',
    title: 'Landing con catálogo',
    description: 'Ideal si necesitas mostrar productos, galerías o un menú de servicios sin complicarte con una tienda completa.',
  },
  {
    number: '03',
    title: 'Sitio corporativo',
    description: 'Para negocios que necesitan varias secciones, diseño más personalizado, formulario de contacto y mejor presencia de marca.',
  },
];
---

<section id="servicios" class="section relative">
  <div class="container-x">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Servicios</div>
        <h2 class="section-title">
          Tres formas simples de empezar tu presencia digital.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          Pensado para quienes necesitan salir bien presentados online sin pagar por complejidad innecesaria.
        </p>
      </div>

      <div class="lg:col-span-8 grid gap-5 md:grid-cols-3">
        {
          services.map((service) => (
            <article class="panel panel-hover flex min-h-[320px] flex-col justify-between p-7">
              <div>
                <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">{service.number}</div>
                <h3 class="mt-10 text-2xl font-semibold tracking-[-0.04em] text-white">{service.title}</h3>
                <p class="mt-4 text-base leading-8 text-brand-muted">{service.description}</p>
              </div>
              <div class="mt-10 flex items-center gap-3 text-sm text-white/75">
                <span class="h-10 w-10 rounded-full border border-white/10 bg-white/[0.04] flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                  </svg>
                </span>
                Hecho para empezar rápido
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
