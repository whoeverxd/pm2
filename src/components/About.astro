---
const projects = [
  {
    label: 'Featured Build 01',
    title: 'A sharper digital presence for a boutique legal firm.',
    description: 'We replaced a dated brochure site with a clear editorial system focused on authority, trust and qualified leads.',
    metrics: ['+42% consultation requests', 'Launch in 3 weeks'],
  },
  {
    label: 'Featured Build 02',
    title: 'A luxury service brand positioned like a market leader.',
    description: 'The new experience paired refined typography with cleaner offers, helping the team close better-fit clients faster.',
    metrics: ['+31% lead quality', '12-country reach'],
  },
];
---

<section id="proyectos" class="section relative">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Featured Projects</div>
        <h2 class="section-title">
          Selected work designed to elevate perception and increase demand.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          Every project is structured like a premium product launch: positioning first, design second,
          execution always.
        </p>
      </div>

      <div class="lg:col-span-8 space-y-6">
        {
          projects.map((project, index) => (
            <article class="panel panel-hover overflow-hidden p-4 sm:p-5">
              <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
                <div class={`rounded-[24px] border border-white/10 p-6 sm:p-8 ${index === 0 ? 'bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.18),transparent_42%),linear-gradient(180deg,#111A30_0%,#0C1324_100%)]' : 'bg-[linear-gradient(180deg,#10192E_0%,#0B1221_100%)]'}`}>
                  <div class="flex items-center justify-between gap-4">
                    <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">{project.label}</div>
                    <div class="rounded-full border border-white/10 px-3 py-1 text-[11px] text-white/70">Desktop Experience</div>
                  </div>
                  <div class="mt-10 grid gap-4 sm:grid-cols-[1.05fr_0.95fr]">
                    <div class="space-y-4">
                      <div class="h-3 w-24 rounded-full bg-white/12"></div>
                      <div class="h-8 w-full rounded-full bg-white/10"></div>
                      <div class="h-8 w-[88%] rounded-full bg-white/10"></div>
                      <div class="h-8 w-[72%] rounded-full bg-white/10"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                      <div class="rounded-[20px] border border-white/10 bg-white/[0.03] p-4">
                        <div class="h-24 rounded-[18px] bg-white/10"></div>
                      </div>
                      <div class="rounded-[20px] border border-white/10 bg-brand-blue/[0.1] p-4">
                        <div class="h-24 rounded-[18px] bg-white/10"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="px-2 sm:px-3 lg:px-4">
                  <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Case Study Summary</div>
                  <h3 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-white sm:text-[2rem]">{project.title}</h3>
                  <p class="mt-4 text-base leading-8 text-brand-muted">{project.description}</p>
                  <div class="mt-6 flex flex-wrap gap-3">
                    {project.metrics.map((metric) => (
                      <div class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-white/80">{metric}</div>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
        </div>
      </div>
    </div>
  </div>
</section>
