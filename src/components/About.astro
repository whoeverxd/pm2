---
const missionCards = [
  {
    title: 'Presencia digital profesional',
    description: 'Ayudamos a venezolanos, negocios y profesionales a verse serios online con una web clara y bien presentada.',
  },
  {
    title: 'Sitios hechos para convertir',
    description: 'Creamos paginas que explican mejor tus servicios, generan confianza y facilitan el primer contacto.',
    featured: true,
  },
  {
    title: 'Soluciones accesibles y reales',
    description: 'Buscamos que mas personas en Venezuela puedan lanzar su sitio web sin procesos pesados ni costos absurdos.',
  },
];
---

<section id="mision" class="section relative">
  <div class="container-x">
    <div class="grid gap-8 xl:grid-cols-[340px_minmax(0,1fr)_390px] xl:items-start">
      <div class="space-y-5">
        {
          missionCards.map((card) => (
            <article class={`rounded-[28px] border p-7 transition duration-300 ${card.featured ? 'border-white/12 bg-white/[0.05]' : 'border-white/8 bg-transparent hover:border-white/16 hover:bg-white/[0.03]'}`}>
              <div class="flex items-start gap-4">
                <div class="mt-1 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-brand-blue/30 bg-brand-blue/[0.08] text-brand-blue">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 12h16M12 4v16" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-[1.75rem] font-semibold tracking-[-0.04em] text-white">{card.title}</h3>
                  <p class="mt-3 text-base leading-8 text-brand-muted">{card.description}</p>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="flex min-h-full flex-col justify-between gap-8">
        <div>
          <div class="eyebrow mb-5">Mision</div>
          <h2 class="heading max-w-[10ch] text-[3rem] leading-[0.9] text-transparent [-webkit-text-stroke:2px_theme(colors.brand.blue)] sm:text-[4rem] lg:text-[5rem] xl:text-[5.4rem]">
            NUESTRA MISION
          </h2>
        </div>

        <div class="min-h-[320px] overflow-hidden rounded-[30px] border border-white/10 bg-brand-surface">
          <img
            src="/multi-ethnic-diverse-business-team-coworkers-colle-KW97Z92.webp"
            alt="Equipo colaborando en una reunion de trabajo"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-1">
        <div class="min-h-[320px] overflow-hidden rounded-[30px] border border-white/10 bg-brand-surface xl:min-h-[540px]">
          <img
            src="/2.webp"
            alt="Equipo revisando trabajo digital en un escritorio"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
