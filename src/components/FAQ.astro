---
const faqs = [
  {
    q: 'What kind of clients are you best for?',
    a: 'Service brands, consultants, studios and premium local businesses that need a website to improve perception and convert better opportunities.',
  },
  {
    q: 'Do you write the copy too?',
    a: 'We usually shape the messaging structure and can refine your existing copy. For deeper content strategy or full copywriting, we scope that as part of the project.',
  },
  {
    q: 'How long does a project usually take?',
    a: 'Most focused landing pages launch in 1 to 2 weeks. More ambitious editorial websites typically take 2 to 4 weeks depending on scope and feedback speed.',
  },
  {
    q: 'Will the site be custom or based on a template?',
    a: 'Custom. We build each project around your offer, audience and brand perception goals. No off-the-shelf layout recycling.',
  },
  {
    q: 'Can you work with my current domain and hosting?',
    a: 'Yes. We can launch on your current setup, recommend a better stack or handle the migration if your existing environment is holding the site back.',
  },
  {
    q: 'Do you offer support after launch?',
    a: 'Yes. We can provide post-launch refinement, updates and ongoing support when the site needs to keep evolving with the business.',
  },
];
---

<section id="faq" class="section relative">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">FAQ</div>
        <h2 class="section-title">
          The practical questions clients ask before we start.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          If your case is unusual, we can scope it directly in a proposal.
        </p>
        <a
          href="https://wa.me/584244074025"
          target="_blank"
          rel="noopener"
          class="btn-secondary mt-6"
        >
          Ask via WhatsApp
        </a>
      </div>

      <div class="lg:col-span-8 space-y-3">
        {
          faqs.map((f) => (
            <details class="group panel p-6 sm:p-7 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="font-semibold text-white text-base sm:text-lg">{f.q}</span>
                <span class="shrink-0 flex h-8 w-8 items-center justify-center rounded-full border border-white/10 bg-white/5 transition group-open:rotate-45 group-open:border-brand-blue group-open:bg-brand-blue">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                </span>
              </summary>
              <p class="mt-4 max-w-3xl text-base leading-8 text-brand-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
