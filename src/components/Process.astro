---
const steps = [
  {
    n: '01',
    title: 'Nos cuentas de tu negocio',
    desc: 'Por WhatsApp o llamada. Nos explicas qué haces, a quién te diriges y qué quieres lograr.',
  },
  {
    n: '02',
    title: 'Diseñamos y desarrollamos',
    desc: 'Nuestros diseñadores y developers crean tu sitio con identidad propia y código optimizado.',
  },
  {
    n: '03',
    title: 'Revisamos juntos',
    desc: 'Te mostramos el resultado, ajustamos los detalles que quieras y afinamos textos.',
  },
  {
    n: '04',
    title: 'Publicamos y capacitamos',
    desc: 'Lanzamos tu sitio en subdominio o dominio propio, y te enseñamos a usarlo.',
  },
];
---

<section class="section relative">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <div class="eyebrow mb-5">Proceso</div>
        <h2 class="section-title">
          De la idea al lanzamiento, en días.
        </h2>
        <p class="mt-6 section-kicker max-w-md">
          Te guiamos sin hacerte perder tiempo con pasos innecesarios.
        </p>
      </div>

      <div class="lg:col-span-8">
        <div class="relative pl-0 lg:pl-8">
          <div class="absolute left-3 top-0 hidden h-full w-px bg-white/10 lg:block"></div>
          <div class="space-y-5">
            {
              steps.map((s) => (
                <article class="panel panel-hover relative p-7 sm:p-8 lg:ml-8">
                  <div class="absolute -left-[45px] top-10 hidden h-6 w-6 rounded-full border border-brand-blue/50 bg-brand-bg shadow-[0_0_0_6px_rgba(6,11,24,1)] lg:block"></div>
                  <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">Paso {s.n}</div>
                  <h3 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-white">{s.title}</h3>
                  <p class="mt-4 max-w-2xl text-base leading-8 text-brand-muted">{s.desc}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
