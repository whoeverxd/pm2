---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="relative border-t border-white/5 pt-16 pb-10">
  <div class="container-x">
    <div class="grid md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <Logo withTagline />
        <p class="mt-5 text-brand-muted max-w-md leading-relaxed">
          Diseñadores y desarrolladores profesionales apoyando a emprendedores latinoamericanos
          a construir su presencia digital a un precio justo.
        </p>
      </div>

      <div>
        <div class="text-xs font-bold uppercase tracking-widest text-brand-yellow">Navegación</div>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="#nosotros" class="text-brand-muted hover:text-white">Nosotros</a></li>
          <li><a href="#servicios" class="text-brand-muted hover:text-white">Servicios</a></li>
          <li><a href="#planes" class="text-brand-muted hover:text-white">Planes</a></li>
          <li><a href="#mantenimiento" class="text-brand-muted hover:text-white">Mantenimiento</a></li>
          <li><a href="#faq" class="text-brand-muted hover:text-white">Preguntas frecuentes</a></li>
        </ul>
      </div>

      <div>
        <div class="text-xs font-bold uppercase tracking-widest text-brand-yellow">Contacto</div>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href="https://wa.me/584244074025" target="_blank" rel="noopener" class="text-brand-muted hover:text-white">
              WhatsApp: +58 424 407-4025
            </a>
          </li>
          <li>
            <a href="https://instagram.com/programmasters.ve" target="_blank" rel="noopener" class="text-brand-muted hover:text-white">
              Instagram: @programmasters.ve
            </a>
          </li>
          <li>
            <a href="mailto:hola@programmasters.net" class="text-brand-muted hover:text-white">
              hola@programmasters.net
            </a>
          </li>
          <li class="text-brand-muted">www.programmasters.net</li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-brand-muted">
      <div>© {year} ProgramMasters. Todos los derechos reservados.</div>
      <div class="flex items-center gap-2">
        <span>Hecho con</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#C0202B">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
        <span>en Venezuela para el mundo</span>
      </div>
    </div>
  </div>
</footer>
