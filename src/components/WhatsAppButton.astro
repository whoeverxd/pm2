---
const phone = '584244074025';
const whatsappBaseMessage = 'Hola ProgramMasters, me interesa un sitio web para mi negocio';
const recipientEmail = 'hola@programmasters.net';
---

<div class="fixed bottom-5 right-5 z-50 group">
  <span class="relative flex items-center gap-3">
    <span class="hidden rounded-full border border-white/10 bg-brand-surface/90 px-4 py-2 text-xs font-semibold text-white opacity-0 shadow-lg backdrop-blur-md transition group-hover:opacity-100 sm:inline-block">
      Start your project
    </span>
    <button
      type="button"
      id="wa-drawer-open"
      aria-label="Abrir formulario de WhatsApp"
      class="relative flex h-14 w-14 items-center justify-center rounded-full border border-white/10 bg-brand-blue text-white shadow-[0_18px_50px_-24px_rgba(59,130,246,0.9)] transition duration-300 hover:scale-105 hover:bg-brand-blueDark"
    >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.52 3.48A11.86 11.86 0 0012.05 0C5.5 0 .16 5.34.16 11.9c0 2.1.55 4.14 1.6 5.95L0 24l6.32-1.66a11.86 11.86 0 005.72 1.46h.01c6.55 0 11.89-5.34 11.89-11.9a11.86 11.86 0 00-3.42-8.42zM12.05 21.77h-.01a9.87 9.87 0 01-5.03-1.38l-.36-.22-3.75.98 1-3.65-.24-.38a9.85 9.85 0 01-1.5-5.22c0-5.45 4.44-9.88 9.9-9.88 2.64 0 5.13 1.03 6.99 2.9a9.83 9.83 0 012.9 6.99c-.01 5.45-4.44 9.86-9.9 9.86zm5.45-7.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.4-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.87 1.22 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.48 1.7.62.71.22 1.36.19 1.87.11.57-.08 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"/>
        </svg>
    </button>
  </span>
</div>

<div id="wa-drawer" class="pointer-events-none fixed inset-0 z-[60] opacity-0 transition duration-300">
  <button
    type="button"
    id="wa-drawer-backdrop"
    class="absolute inset-0 bg-[#020611]/70 backdrop-blur-sm"
    aria-label="Cerrar formulario"
  ></button>

  <aside class="absolute inset-x-3 bottom-3 max-h-[calc(100vh-1.5rem)] overflow-hidden rounded-[28px] border border-white/10 bg-[#08101F]/96 shadow-[0_32px_120px_-42px_rgba(0,0,0,0.9)] transition duration-300 sm:inset-x-auto sm:right-5 sm:bottom-5 sm:w-[420px] sm:max-h-[680px]">
    <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
      <div class="flex items-center gap-3">
        <img src="/isotipo.png" alt="" width="32" height="32" class="shrink-0 rounded-full object-contain" aria-hidden="true" />
        <div>
          <div class="text-sm font-semibold text-white">Contactanos via WhatsApp</div>
          <div class="text-xs text-brand-muted">Respuesta inicial en pocos minutos</div>
        </div>
      </div>
      <button
        type="button"
        id="wa-drawer-close"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-white transition hover:border-brand-yellow/40 hover:text-brand-yellowSoft"
        aria-label="Cerrar"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <div class="flex max-h-[inherit] flex-col">
      <div class="border-b border-white/10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.18),transparent_48%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent)] px-5 py-5"></div>

      <form id="wa-lead-form" class="flex flex-1 flex-col gap-4 overflow-y-auto px-5 py-5">
        <input type="hidden" name="_subject" value="Nuevo lead desde drawer de WhatsApp" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-white">Tu nombre</span>
          <input
            type="text"
            name="name"
            required
            placeholder="Ej. Carlos Pérez"
            class="w-full rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white outline-none transition placeholder:text-brand-muted focus:border-brand-blue"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-white">Tu teléfono</span>
          <input
            type="tel"
            name="phone"
            required
            inputmode="tel"
            placeholder="Ej. +58 424 123 4567"
            class="w-full rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white outline-none transition placeholder:text-brand-muted focus:border-brand-blue"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-medium text-white">Tu mensaje</span>
          <textarea
            name="message"
            rows="4"
            required
            placeholder="Envianos un mensaje, rompe el hielo con nosotros, estamos aqui para ayudarte."
            class="w-full resize-none rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3 text-white outline-none transition placeholder:text-brand-muted focus:border-brand-blue"
          ></textarea>
        </label>

        <div id="wa-form-status" class="hidden rounded-2xl border px-4 py-3 text-sm"></div>

        <div class="mt-auto flex flex-col gap-3 border-t border-white/10 pt-4">
          <button type="submit" class="btn-primary w-full justify-center">
            Enviar mensaje
          </button>
        </div>
      </form>
    </div>
  </aside>
</div>

<script define:vars={{ phone, whatsappBaseMessage, recipientEmail }}>
  const openButton = document.getElementById('wa-drawer-open');
  const drawer = document.getElementById('wa-drawer');
  const closeButton = document.getElementById('wa-drawer-close');
  const backdrop = document.getElementById('wa-drawer-backdrop');
  const form = document.getElementById('wa-lead-form');
  const status = document.getElementById('wa-form-status');
  const body = document.body;

  const setDrawer = (open) => {
    if (!drawer) return;

    drawer.classList.toggle('pointer-events-none', !open);
    drawer.classList.toggle('opacity-0', !open);
    body.classList.toggle('overflow-hidden', open);
  };

  const showStatus = (message, mode) => {
    if (!status) return;

    status.textContent = message;
    status.className = 'rounded-2xl border px-4 py-3 text-sm';
    status.classList.remove('hidden');

    if (mode === 'error') {
      status.classList.add('border-red-500/30', 'bg-red-500/10', 'text-red-100');
      return;
    }

    status.classList.add('border-brand-yellow/20', 'bg-brand-yellow/[0.08]', 'text-white');
  };

  const openWhatsApp = (name, phoneNumber, message) => {
    const parts = [
      whatsappBaseMessage,
      `Mi nombre es ${name}.`,
      `Mi telefono es ${phoneNumber}.`,
      message,
    ].filter(Boolean);

    const url = `https://wa.me/${phone}?text=${encodeURIComponent(parts.join(' '))}`;
    window.open(url, '_blank', 'noopener');
  };

  openButton?.addEventListener('click', () => setDrawer(true));
  closeButton?.addEventListener('click', () => setDrawer(false));
  backdrop?.addEventListener('click', () => setDrawer(false));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setDrawer(false);
    }
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const currentForm = event.currentTarget;
    if (!(currentForm instanceof HTMLFormElement)) return;

    const submitButton = currentForm.querySelector('button[type="submit"]');
    const formData = new FormData(currentForm);
    const name = String(formData.get('name') || '').trim();
    const phoneNumber = String(formData.get('phone') || '').trim();
    const message = String(formData.get('message') || '').trim();
    const honeypot = String(formData.get('website') || '').trim();

    if (honeypot) return;

    if (!name || !phoneNumber || !message) {
      showStatus('Necesitamos tu nombre, teléfono y mensaje.', 'error');
      return;
    }

    submitButton?.setAttribute('disabled', 'disabled');
    submitButton?.classList.add('opacity-70', 'cursor-not-allowed');

    formData.append('_template', 'table');
    formData.append('source', 'WhatsApp drawer');
    formData.append('phone_number', phoneNumber);

    try {
      const response = await fetch(`https://formsubmit.co/ajax/${recipientEmail}`, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
        },
        body: formData,
      });

      if (!response.ok) {
        throw new Error('Lead submit failed');
      }

      showStatus('Datos guardados. Abriendo WhatsApp...', 'success');
      currentForm.reset();
      openWhatsApp(name, phoneNumber, message);
      window.setTimeout(() => setDrawer(false), 900);
    } catch (error) {
      showStatus('No pudimos guardar tus datos ahora mismo. Puedes continuar por WhatsApp y luego revisamos la captura.', 'error');
      openWhatsApp(name, phoneNumber, message);
    } finally {
      submitButton?.removeAttribute('disabled');
      submitButton?.classList.remove('opacity-70', 'cursor-not-allowed');
    }
  });
</script>
