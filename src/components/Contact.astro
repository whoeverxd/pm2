---
const contactCards = [
  {
    label: 'WhatsApp',
    value: '+58 424 407-4025',
    href: 'https://wa.me/584244074025',
  },
  {
    label: 'Instagram',
    value: '@programmasters.ve',
    href: 'https://instagram.com/programmasters.ve',
  },
  {
    label: 'Email',
    value: 'hola@programmasters.net',
    href: 'mailto:hola@programmasters.net',
  },
  {
    label: 'Call',
    value: '+58 424 407-4025',
    href: 'tel:+584244074025',
  },
];
---

<section id="contacto" class="section relative">
  <div class="container-x">
    <div class="panel relative overflow-hidden rounded-[28px] p-8 sm:p-12 lg:p-14">
      <div class="absolute -right-16 top-0 h-64 w-64 rounded-full bg-brand-blue/20 blur-3xl"></div>
      <div class="absolute left-10 top-10 h-32 w-32 rounded-full bg-white/[0.05] blur-3xl"></div>

      <div class="relative grid gap-10 lg:grid-cols-12 lg:items-stretch">
        <div class="lg:col-span-7">
          <div class="eyebrow mb-5">Contacto</div>
          <h2 class="section-title max-w-4xl">
            <span class="text-transparent [-webkit-text-stroke:2px_theme(colors.brand.blue)]">Tu sitio</span> web puede estar listo esta semana.
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-brand-muted">
            Cuéntanos qué haces, a quién atiendes y qué necesitas mostrar. Te proponemos una solución clara para empezar tu presencia digital sin complicaciones.
          </p>

          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a
              href="https://wa.me/584244074025?text=Hola%20ProgramMasters%2C%20quiero%20informaci%C3%B3n%20sobre%20un%20sitio%20web"
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              Solicitar propuesta
            </a>
            <a href="#planes" class="btn-secondary">Ver precios</a>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="grid gap-3 sm:grid-cols-2 lg:flex lg:h-full lg:flex-col lg:justify-between lg:gap-4">
            {
              contactCards.map((card) => (
                <a href={card.href} target={card.href.startsWith('http') ? '_blank' : undefined} rel={card.href.startsWith('http') ? 'noopener' : undefined} class="panel panel-hover p-5 lg:flex-1">
                  <div class="text-[11px] uppercase tracking-[0.24em] text-brand-muted">{card.label}</div>
                  <div class="mt-4 text-lg font-semibold tracking-[-0.03em] text-white">{card.value}</div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
