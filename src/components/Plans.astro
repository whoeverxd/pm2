---
const plans = [
  {
    id: 'starter',
    label: 'Starter',
    name: 'Launch Page',
    price: '$900',
    delivery: 'Ideal for a focused service offer',
    features: [
      'Custom homepage design',
      'Conversion-focused messaging structure',
      'Responsive build and speed optimization',
      'Inquiry or WhatsApp CTA integration',
      'Launch support and QA',
    ],
    ctaText: 'Request Starter',
    ctaMessage: 'Hola%20ProgramMasters%2C%20me%20interesa%20el%20plan%20Launch%20Page',
  },
  {
    id: 'signature',
    label: 'Signature',
    name: 'Agency Website',
    price: '$1,800',
    delivery: 'For brands that need depth and authority',
    highlight: true,
    features: [
      'Multi-section editorial website',
      'Visual direction and premium UI system',
      'Advanced conversion structure',
      'Portfolio, services and proof modules',
      'Launch support and analytics baseline',
    ],
    ctaText: 'Request Signature',
    ctaMessage: 'Hola%20ProgramMasters%2C%20me%20interesa%20el%20plan%20Agency%20Website',
  },
  {
    id: 'atelier',
    label: 'Atelier',
    name: 'Custom Growth System',
    price: 'Custom',
    delivery: 'For premium brands with wider scope',
    features: [
      'Strategy workshop and positioning review',
      'Custom pages, case studies and funnels',
      'Design system for future expansion',
      'Advanced integrations and launch planning',
      'Priority collaboration',
    ],
    ctaText: 'Book Discovery',
    ctaMessage: 'Hola%20ProgramMasters%2C%20quiero%20hablar%20sobre%20un%20proyecto%20Custom%20Growth%20System',
  },
];
---

<section id="planes" class="section relative">
  <div class="container-x">
    <div class="max-w-3xl">
      <div class="eyebrow mb-5 inline-flex">Pricing</div>
      <h2 class="section-title max-w-4xl">
        Clear packages for teams that want premium work without enterprise bloat.
      </h2>
      <p class="mt-6 editorial-copy">
        These ranges keep the engagement simple. Final pricing depends on scope, content readiness and the amount of strategy your team needs.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        plans.map((plan) => (
            <div
              class={`panel relative flex flex-col overflow-hidden p-8 sm:p-10 ${plan.highlight ? 'border-brand-blue/40 bg-[linear-gradient(180deg,rgba(59,130,246,0.14),rgba(13,21,40,0.94))]' : ''}`}
            >
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.03),transparent_24%)] pointer-events-none"></div>

              {plan.highlight && (
                <div class="absolute right-5 top-5 rounded-full border border-brand-blue/40 bg-brand-blue/12 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-white">
                  Most Requested
                </div>
              )}

              <div class="relative">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-muted">
                  {plan.label}
                </span>

                <h3 class="mt-6 text-3xl font-semibold tracking-[-0.05em] text-white">{plan.name}</h3>

                <div class="mt-8 flex items-end gap-2">
                  <span class="font-display text-5xl tracking-[-0.06em] text-white sm:text-6xl">{plan.price}</span>
                </div>

                <div class="mt-3 text-sm leading-7 text-brand-muted">{plan.delivery}</div>

                <div class="my-8 h-px bg-white/10"></div>

                <ul class="space-y-4 text-sm">
                  {plan.features.map((f) => (
                    <li class="flex items-start gap-3">
                      <svg class="mt-0.5 shrink-0 text-brand-blue" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M5 12l5 5L20 7"/>
                      </svg>
                      <span class="text-white/90 leading-7">{f}</span>
                    </li>
                  ))}
                </ul>

                <a
                  href={`https://wa.me/584244074025?text=${plan.ctaMessage}`}
                  target="_blank"
                  rel="noopener"
                  class={`mt-10 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold transition ${plan.highlight ? 'bg-brand-blue text-white hover:bg-brand-blueDark hover:shadow-glow' : 'border border-white/10 bg-white/[0.04] text-white hover:border-white/20 hover:bg-white/[0.07]'}`}
                >
                  {plan.ctaText}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          ))
      }
    </div>

    <div class="mt-10 text-sm text-brand-muted">
      Need a tailored scope? <a href="#contacto" class="font-semibold text-white transition hover:text-brand-blue">Let’s shape it together.</a>
    </div>
  </div>
</section>
