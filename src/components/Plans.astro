---
const plans = [
  {
    id: 'starter',
    label: 'Plan 1',
    name: 'Landing sencilla',
    price: '$50',
    delivery: 'Ideal para comenzar con una presencia simple y profesional',
    features: [
      '1 página con información clave, horarios o precios',
      'Botón directo a WhatsApp',
      'Código QR para compartir',
      'Subdominio propio',
      'Perfil de Google Business opcional',
    ],
    ctaText: 'Consultar Plan 1',
    ctaMessage: 'Hola%20ProgramMasters%2C%20me%20interesa%20el%20Plan%201%20Landing%20sencilla',
  },
  {
    id: 'signature',
    label: 'Plan 2',
    name: 'Landing con catálogo',
    price: '$90',
    delivery: 'Para mostrar productos, menús, servicios o galería',
    highlight: true,
    features: [
      'Todo lo del Plan 1',
      'Galería de fotos o catálogo de productos',
      'Diseño más personalizado',
      'QR con reseñas de Google',
      'Mejor estructura para vender o cotizar',
    ],
    ctaText: 'Consultar Plan 2',
    ctaMessage: 'Hola%20ProgramMasters%2C%20me%20interesa%20el%20Plan%202%20Landing%20con%20cat%C3%A1logo',
  },
  {
    id: 'atelier',
    label: 'Plan 3',
    name: 'Sitio corporativo',
    price: 'Desde $250',
    delivery: 'Para negocios que necesitan más secciones y presencia de marca',
    features: [
      '5 a 7 páginas: inicio, nosotros, servicios y contacto',
      'Diseño más personalizado',
      'Formulario de contacto',
      'Dominio propio incluido',
      'SEO básico y analítica inicial',
    ],
    ctaText: 'Consultar Plan 3',
    ctaMessage: 'Hola%20ProgramMasters%2C%20me%20interesa%20el%20Plan%203%20Sitio%20corporativo',
  },
];
---

<section id="planes" class="section relative">
  <div class="container-x">
    <div class="max-w-3xl">
      <div class="eyebrow mb-5 inline-flex">Planes</div>
      <h2 class="section-title max-w-4xl">
        Planes claros para comenzar sin complicarte.
      </h2>
      <p class="mt-6 editorial-copy">
        Estos precios sirven como base para negocios y profesionales que quieren arrancar rápido. Si tu caso necesita más alcance, lo ajustamos contigo.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        plans.map((plan) => (
            <div
              class={`panel relative flex flex-col overflow-hidden p-8 sm:p-10 ${plan.highlight ? 'border-brand-blue/40 bg-[linear-gradient(180deg,rgba(59,130,246,0.14),rgba(13,21,40,0.94))]' : ''}`}
            >
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.03),transparent_24%)] pointer-events-none"></div>

              {plan.highlight && (
                <div class="absolute right-5 top-5 rounded-full border border-brand-blue/40 bg-brand-blue/12 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-white">
                  Más solicitado
                </div>
              )}

              <div class="relative">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-brand-muted">
                  {plan.label}
                </span>

                <h3 class="mt-6 text-3xl font-semibold tracking-[-0.05em] text-white">{plan.name}</h3>

                <div class="mt-8 flex items-end gap-2">
                  <span class="font-display text-5xl tracking-[-0.06em] text-white sm:text-6xl">{plan.price}</span>
                </div>

                <div class="mt-3 text-sm leading-7 text-brand-muted">{plan.delivery}</div>

                <div class="my-8 h-px bg-white/10"></div>

                <ul class="space-y-4 text-sm">
                  {plan.features.map((f) => (
                    <li class="flex items-start gap-3">
                      <svg class="mt-0.5 shrink-0 text-brand-blue" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M5 12l5 5L20 7"/>
                      </svg>
                      <span class="text-white/90 leading-7">{f}</span>
                    </li>
                  ))}
                </ul>

                <a
                  href={`https://wa.me/584244074025?text=${plan.ctaMessage}`}
                  target="_blank"
                  rel="noopener"
                  class={`mt-10 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold transition ${plan.highlight ? 'bg-brand-blue text-white hover:bg-brand-blueDark' : 'border border-white/10 bg-white/[0.04] text-white hover:border-white/20 hover:bg-white/[0.07]'}`}
                >
                  {plan.ctaText}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          ))
      }
    </div>

    <div class="mt-10 text-sm text-brand-muted">
      ¿Necesitas algo más a medida? <a href="#contacto" class="font-semibold text-white transition hover:text-brand-blue">Lo revisamos contigo.</a>
    </div>
  </div>
</section>
